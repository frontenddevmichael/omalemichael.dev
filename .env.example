# This file is safe to commit -- it's a template, not real secrets.
#
# GITHUB_TOKEN: used two places, both server-side only, NEVER prefixed VITE_:
#   1. Locally: create a real .env (gitignored) with GITHUB_TOKEN=... and
#      `npm run dev` will pick it up via vite.config.js's dev middleware,
#      so you can preview the contribution graph locally.
#   2. In production: set the same variable in your host's dashboard
#      (e.g. Vercel Project Settings -> Environment Variables) for
#      /api/contributions.js to use.
GITHUB_TOKEN=
